# Firebase Web SDK 設定（Firebaseコンソール > プロジェクト設定 > マイアプリ から取得）
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxx

# ローカル開発でFirebase Emulatorに接続する場合は true
VITE_USE_EMULATOR=false

# ============================================================
# Cloud Functions（Unit 4）— AIプロバイダ設定
# ※ APIキーは本番では Secret Manager で管理（ローカルEmulator時のみ .env 利用）
# ============================================================

# 使用するLLMプロバイダ: anthropic | openai | mock（デフォルト: anthropic）
LLM_PROVIDER=anthropic

# Anthropic Claude（LLM_PROVIDER=anthropic 時）
ANTHROPIC_API_KEY=your-anthropic-api-key
# ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# OpenAI（LLM_PROVIDER=openai 時）
OPENAI_API_KEY=your-openai-api-key
# OPENAI_MODEL=gpt-4o-mini

# ローカル開発でClaude/OpenAIを呼ばず固定レスポンスを使う場合は true（後方互換）
CLAUDE_MOCK=false
