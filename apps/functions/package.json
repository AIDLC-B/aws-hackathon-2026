{
  "name": "@damesi/functions",
  "private": true,
  "version": "0.1.0",
  "description": "DAMESI Cloud Functions（Unit 4: CF-01/02/03）",
  "type": "module",
  "main": "lib/functions/src/index.js",
  "engines": {
    "node": "20"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "serve": "npm run build && firebase emulators:start --only functions",
    "deploy": "firebase deploy --only functions"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.1",
    "firebase-admin": "^12.5.0",
    "firebase-functions": "^6.1.0",
    "openai": "^4.67.3"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
