{
  "name": "damesi",
  "private": true,
  "version": "0.1.0",
  "description": "DAMESI（ダメシ）モノレポ・ルート（npm workspaces）",
  "type": "module",
  "workspaces": [
    "apps/shared",
    "apps/web",
    "apps/functions",
    "apps/seed"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @damesi/web",
    "build": "npm run build --workspace @damesi/web",
    "build:functions": "npm run build --workspace @damesi/functions",
    "preview": "npm run preview --workspace @damesi/web",
    "lint": "npm run lint --workspace @damesi/web",
    "typecheck": "npm run typecheck --workspace @damesi/web && npm run typecheck --workspace @damesi/functions",
    "test": "npm run test --workspace @damesi/web && npm run test --workspace @damesi/functions",
    "test:rules": "npm run test:rules --workspace @damesi/web",
    "seed": "npm run seed --workspace @damesi/seed",
    "emulators": "firebase emulators:start",
    "deploy": "firebase deploy"
  }
}
